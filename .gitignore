# Xcode
build/
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
xcuserdata/

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins
# Package.resolved is intentionally tracked — this is an executable app,
# not a library; locking dependency versions ensures reproducible builds.

# Stray compile artifacts if they leak into root
/*.d
/*.o
/*.swiftdeps
/*.swiftdeps~

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Environment / secrets
.env
.env.local

# Logs and crash reports
*.log
crash.log

# User library data (generated at runtime, never source)
Library/
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Test artifacts
*.xctestrun
coverage/
*.gcno
*.gcda

# Models (按需下载，不入 git)
models/*.mlmodel
models/*.mlmodelc
Resources/Models/

# Fonts (外购，按需添加；不含源字体文件)
Resources/Fonts/*.otf
Resources/Fonts/*.ttf
!Resources/Fonts/.gitkeep
